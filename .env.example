# ── גבר / Gever — environment variables ──
# Copy to .env and fill in. Never commit .env.

# ── Stage 0: Browserbase + Stagehand (PoC) ──
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# The LLM that DRIVES the browser (Stagehand). gemini-3-flash-preview — Stagehand-
# validated (73.8% on act/observe/extract) and won our live Ontopo A/B vs 3.5-flash.
MODEL_NAME=google/gemini-3-flash-preview

# ── Stage 1: conversation model (Gemini) ──
# User-facing intent + clarifying questions + replies (cheap, high volume).
# Strong colloquial Hebrew matters for the גבר persona — stay on Gemini.
# gemini-3.5-flash is the default (strong colloquial Hebrew).
GEMINI_API_KEY=

# Brave Search API — מנוע ה-resolve בפרודקשן (DDG חוסם דטהסנטר). https://api-dashboard.search.brave.com
BRAVE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Real booking OFF by default: "מאשר" reaches the confirmation screen and stops
# (no real booking). Flip to false in .env/Coolify for a real booking, while watching.
DRY_RUN=true

# -- Stage 1: WhatsApp via Meta Cloud API --
# From Meta app -> WhatsApp -> API Setup: Temporary access token + Phone number ID.
# WHATSAPP_VERIFY_TOKEN is your own choice; it must match the webhook config in the Meta dashboard.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=gever_verify_2026
WHATSAPP_API_VERSION=v21.0
# ngrok dev domain הקבוע ל-tunnel המקומי (scripts/tunnel.sh). ראה docs/ops-tunnel.md.
# dev בלבד — פרודקשן רץ על Coolify/DuckDNS בלי tunnel
NGROK_DOMAIN=

# ── Stage 2 — not read by config yet (re-added when the arm starts): Supabase ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Stage 2 — not read by config yet (re-added when the arm starts): encryption (user PII at rest) ──
# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Stage 2 — not read by config yet (re-added when the arm starts): Lemon Squeezy (subscriptions) ──
# Merchant of Record — hosts checkout & handles VAT, so we never touch card data.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
