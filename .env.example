# ── גבר / Gever — environment variables ──
# Copy to .env and fill in. Never commit .env.

# ── Stage 0: Browserbase + Stagehand (PoC) ──
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# The LLM that DRIVES the browser (Stagehand).
# PoC: use the most accurate model — fable-5 tops the Stagehand eval (90.6%, Jun 2026).
#      Cost per PoC run is pennies, so buy reliability for a clean go/no-go.
# Production (later): route most tasks to a cheap workhorse (google/gemini-3-flash-preview)
#      and fall back to anthropic/claude-fable-5 on hard pages. See README.
MODEL_API_KEY=
MODEL_NAME=anthropic/claude-fable-5

# ── Stage 1: conversation model (Gemini Flash) ──
# Intent understanding + clarifying questions + replies (cheap, high volume).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Stage 1: WhatsApp via Twilio ──
# Twilio Sandbox needs zero Meta approval — start dev immediately.
# Sandbox "from" is shared (e.g. whatsapp:+14155238886); swap for your sender in prod.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Stage 1: Supabase ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Stage 2: encryption (user PII at rest) ──
# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Stage 2: Lemon Squeezy (subscriptions) ──
# Merchant of Record — hosts checkout & handles VAT, so we never touch card data.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
