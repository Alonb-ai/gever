# ── גבר / Gever — environment variables ──
# Copy to .env and fill in. Never commit .env.

# ── Stage 0: Browserbase + Stagehand (PoC) ──
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# The LLM that DRIVES the browser (Stagehand). Mid-tier navigator — good
# accuracy at reasonable cost. Sonnet 4.6 = $3/$15 per 1M tokens.
MODEL_API_KEY=
MODEL_NAME=anthropic/claude-sonnet-4-6

# ── Stage 1: conversation model (Gemini) ──
# User-facing intent + clarifying questions + replies (cheap, high volume).
# Strong colloquial Hebrew matters for the גבר persona — stay on Gemini.
# gemini-2.5-flash ($0.30/$2.50) is the default; gemini-2.5-flash-lite
# ($0.10/$0.40) is the cost-optimized option to A/B if Hebrew quality holds.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Stage 1: WhatsApp via Twilio ──
# Twilio Sandbox needs zero Meta approval — start dev immediately.
# Sandbox "from" is shared (e.g. whatsapp:+14155238886); swap for your sender in prod.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Stage 1: Supabase ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Stage 2: encryption (user PII at rest) ──
# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Stage 2: Lemon Squeezy (subscriptions) ──
# Merchant of Record — hosts checkout & handles VAT, so we never touch card data.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
